{
  "id": "wfrp2e",
  "title": "Warhammer Fantasy Roleplay 2nd Edition",
  "description": "A comprehensive system for running grim and perilous games of Warhammer Fantasy Roleplay 2nd Edition in the Foundry VTT environment.",
  "version": "1.0.0",
  "authors": [
    {
      "name": "Moo Man",
      "email": "russellt@cubicle7games.com",
      "discord": "moo.man",
      "reddit": "u/mooman10"
    },
    {
      "name": "CatoThe1stElder"
    }
  ],
  "esmodules": [],
  "scripts": [
    "wfrp2e.js",
    "./libs/pixi-filters.js"
  ],
  "styles": [
    "wfrp2e.css"
  ],
  "packs": [
    {
      "name": "basic",
      "label": "Basic Items",
      "system": "wfrp2e",
      "path": "./packs/basic",
      "type": "Item"
    },
    {
      "name": "careers",
      "label": "Careers",
      "system": "wfrp2e",
      "path": "./packs/careers",
      "type": "Item"
    },
    {
      "name": "skills",
      "label": "Skills",
      "system": "wfrp2e",
      "path": "./packs/skills",
      "type": "Item"
    },
    {
      "name": "talents",
      "label": "Talents",
      "system": "wfrp2e",
      "path": "./packs/talents",
      "type": "Item"
    },
    {
      "name": "spells",
      "label": "Spells",
      "system": "wfrp2e",
      "path": "./packs/spells",
      "type": "Item"
    },
    {
      "name": "blessings",
      "label": "Blessings",
      "system": "wfrp2e",
      "path": "./packs/blessings",
      "type": "Item"
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "media": [
    {
      "type": "cover",
      "url": "https://user-images.githubusercontent.com/28637157/97379891-e4a1cc00-1893-11eb-9e0c-d93b92844d5b.jpg"
    }
  ],
  "flags": {
    "hotReload": {
      "extensions": [
        "css",
        "hbs",
        "json"
      ]
    }
  },
  "initiative": "@characteristics.ag.value + 1d10",
  "background": "systems/wfrp2e/WFRP-Header.jpg",
  "grid": {
    "distance": 2,
    "units": "yd",
    "type": 1,
    "diagonals": 4
  },
  "primaryTokenAttribute": "status.wounds",
  "secondaryTokenAttribute": "status.fortune",
  "compatibility": {
    "minimum": 13,
    "verified": 14,
    "maximum": 14
  },
  "relationships": {
    "requires": [
      {
        "id": "warhammer-lib",
        "type": "module",
        "manifest": "https://raw.githubusercontent.com/moo-man/WarhammerLibrary-FVTT/3.2.0/module.json",
        "compatibility": {
          "minimum": "2.10.0",
          "verified": "3.2.0"
        }
      }
    ]
  },
  "socket": true,
  "manifest": "https://github.com/muruumuys-collab/my-system/releases/latest/download/system.json",
  "download": "https://github.com/muruumuys-collab/my-system/releases/download/1.0.0/wfrp2e.zip",
  "url": "https://github.com/muruumuys-collab/my-system"
}
